{
  "name": "cloudflare-quiz",
  "version": "1.0.0",
  "description": "Cloudflare をプロダクト開発に活かせるようになるための学習クイズ PWA",
  "author": "Cloudflare Codex Quiz Contributors",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write src/ scripts/",
    "format:check": "biome format src/ scripts/",
    "lint": "biome check src/ scripts/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "quiz:randomize": "node scripts/quiz-utils.mjs randomize",
    "quiz:stats": "node scripts/quiz-utils.mjs stats",
    "quiz:check": "node scripts/quiz-utils.mjs check && node scripts/quiz-utils.mjs check-ellipsis",
    "generate-icons": "node scripts/generate-icons.mjs"
  },
  "dependencies": {
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "^2.4.16",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8"
  },
  "type": "module"
}
